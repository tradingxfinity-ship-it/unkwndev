# =========================================================================
# UNKWN — backend environment variables
#
# Copy this file to `.env.local` (Vite reads it for `vercel dev`), and set
# the same values in Vercel → Project → Settings → Environment Variables for
# production. NEVER commit .env.local — it's gitignored.
# =========================================================================

# --- Supabase --------------------------------------------------------------
# Project URL: Dashboard → Project Settings → API → Project URL
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Service role key: Dashboard → Project Settings → API → service_role (secret)
# This bypasses RLS — KEEP IT SERVER-SIDE ONLY. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=

# Salt for the SHA-256 IP hash. Pick anything random (32+ chars), and don't
# rotate it casually — that breaks repeat-IP detection on old rows.
IP_HASH_SALT=change-me-to-a-long-random-string

# --- Resend (email) --------------------------------------------------------
# https://resend.com → API Keys → Create API Key
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Verified sender. Until you verify your own domain on Resend, you can use
# `onboarding@resend.dev` (Resend's shared sandbox sender).
# Format: "Name <email@domain>"  OR  bare "email@domain"
RESEND_FROM_EMAIL=UNKWN <onboarding@resend.dev>

# Where new-signup admin notifications go. Comma-separated list is allowed.
ADMIN_EMAIL=you@example.com

# --- Site metadata ---------------------------------------------------------
SITE_NAME=UNKWN
SITE_URL=https://your-vercel-domain.vercel.app

# --- Security --------------------------------------------------------------
# Comma-separated allowlist of origins permitted to call /api/subscribe.
# Leave empty in dev to allow "*". In production set this to your domain(s).
# Example: https://unkwn.dev,https://www.unkwn.dev
ALLOWED_ORIGINS=
